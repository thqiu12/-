# データベース設定
DATABASE_URL="file:./dev.db"

# セッションシークレット（必須・16文字以上のランダム文字列）
# 未設定だと管理APIは全てフェイルクローズ（アクセス拒否）になります。
# 生成例: openssl rand -hex 32
SESSION_SECRET=""

# アップロードディレクトリ（必ず public/ の外を指すこと。デフォルト: ./storage/uploads）
# public/ 配下に置くと、書類が誰でもアクセス可能な静的ファイルとして配信されてしまいます。
UPLOAD_DIR="./storage/uploads"

# 最大ファイルサイズ（MB）
MAX_FILE_SIZE_MB="10"
